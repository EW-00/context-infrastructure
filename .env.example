# ============================================================
# .env.example
# 复制为 .env 并填写你自己的值。
# 当前个人电脑主路径：launchd + OpenCode Server + observer / reflector
# ============================================================

# Core: OpenCode Server（observer / reflector / 其他 Agent 任务）
OPENCODE_BASE_URL=http://localhost:4096
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=
OPENCODE_MESSAGE_TIMEOUT=3600
OPENCODE_AGENT=build

# Core: OpenAI（semantic_search 本地 embedding；也可供其他工具复用）
OPENAI_API_KEY=

# Optional: Gmail（send_email / crontab_monitor 告警邮件）
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENTS=

# Optional: Google Analytics 4（ga4_metrics.py）
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Kit / ConvertKit（kit_metrics.py 和 newsletter 发布）
KIT_API_KEY=

# Optional: Typefully（typefully_metrics.py，需从浏览器抓取）
TYPEFULLY_AUTHORIZATION=
TYPEFULLY_ACCOUNT=
TYPEFULLY_SESSION=

# Optional: Gemini（图片生成）
GEMINI_API_KEY=
